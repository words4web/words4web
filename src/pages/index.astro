---
import Layout from '../layouts/Layout.astro';
import { SmoothScroll } from '../components/SmoothScroll';
import { CustomCursor } from '../components/CustomCursor';
import { Navbar } from '../components/Navbar';
import { Hero } from '../components/Hero';
import { About } from '../components/About';
import { Services } from '../components/Services';
import { CaseStudies } from '../components/CaseStudies';
import { Testimonials } from '../components/Testimonials';
import { Contact } from '../components/Contact';
import { Footer } from '../components/Footer';
---

<Layout>
  <SmoothScroll client:load />
  <CustomCursor client:load />
  
  <div class="relative w-full min-h-screen selection:bg-[var(--primary)] selection:text-white">
    <Navbar client:load />
    <main>
      <Hero client:load />
      <About client:visible />
      <Services client:visible />
      <CaseStudies client:visible />
      <Testimonials client:visible />
      <Contact client:visible />
    </main>
    <Footer />
  </div>
</Layout>
